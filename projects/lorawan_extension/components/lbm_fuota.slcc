id: lbm_fuota
label: LoRa Basic Modem FUOTA Support
package: lbm
description: Firmware Update Over The Air (FUOTA) support
category: Third Party|LoRaWAN|LBM Features
quality: experimental

root_path: "components/SWL2001/lbm_lib"

provides:
  - name: lbm_fuota

requires:
  - name: lbm_lib
  - name: lbm_class_b
  - name: lbm_class_c
  - name: bootloader_interface
define:
  - name: ADD_FUOTA
  - name: USE_FUOTA
  - name: LBM_FUOTA
    value: "1"
  - name: LBM_FUOTA_VERSION
    value: "1"
  - name: ADD_CLASS_B
  - name: ADD_CLASS_C
  - name: SMTC_MULTICAST
  - name: LBM_MULTICAST
    value: "1"
  - name: ENABLE_FUOTA_ALC_SYNC
  - name: ADD_SMTC_ALC_SYNC
  - name: LBM_ALC_SYNC
    value: "1"
  - name: LBM_ALC_SYNC_VERSION
    value: "1"
  - name: ENABLE_FUOTA_FMP
  - name: LBM_FUOTA_ENABLE_FMP
    value: "1"
  - name: ENABLE_FUOTA_MPA
  - name: LBM_FUOTA_ENABLE_MPA
    value: "1"
  - name: FRAG_MAX_NB
    value: "1500"
  - name: FRAG_MAX_SIZE
    value: "242"
  - name: FRAG_MAX_REDUNDANCY
    value: "100"
  - name: MODEM_BEACON_APP

source:
  - path: smtc_modem_core/lorawan_packages/application_layer_clock_synchronization/v1.0.0/lorawan_alcsync_v1.0.0.c
  - path: smtc_modem_core/lorawan_packages/firmware_management_protocol/lorawan_fmp_package.c
  - path: smtc_modem_core/lorawan_packages/fragmented_data_block_transport/v1.0.0/lorawan_fragmentation_package_v1.0.0.c
  - path: smtc_modem_core/lorawan_packages/fragmented_data_block_transport/v1.0.0/fragmentation_helper_v1.0.0.c
  - path: smtc_modem_core/lorawan_packages/multi_package_access/lorawan_mpa_package.c
  - path: smtc_modem_core/lorawan_packages/remote_multicast_setup/v1.0.0/lorawan_remote_multicast_setup_package_v1.0.0.c
  - path: smtc_modem_core/smtc_modem_crypto/soft_secure_element/cmac.c
  - path: smtc_modem_core/smtc_modem_crypto/soft_secure_element/aes.c
  - path: smtc_modem_core/modem_services/beacon_tx_service/lorawan_beacon_tx_service_example.c

include:
  - path: smtc_modem_core/lorawan_packages/application_layer_clock_synchronization
    file_list:
      - path: lorawan_alcsync.h
  - path: smtc_modem_core/lorawan_packages/firmware_management_protocol
    file_list:
      - path: lorawan_fmp_package.h
  - path: smtc_modem_core/lorawan_packages/fragmented_data_block_transport
    file_list:
      - path: lorawan_fragmentation_package.h
  - path: smtc_modem_core/lorawan_packages/fragmented_data_block_transport/v1.0.0
    file_list:
      - path: fragmentation_helper_v1.0.0.h
  - path: smtc_modem_core/lorawan_packages/multi_package_access
    file_list:
      - path: lorawan_mpa_package.h
  - path: smtc_modem_core/lorawan_packages/remote_multicast_setup
    file_list:
      - path: lorawan_remote_multicast_setup_package.h
  - path: smtc_modem_core/smtc_modem_crypto/soft_secure_element
    file_list:
      - path: cmac.h
      - path: aes.h
  - path: smtc_modem_core/modem_services/beacon_tx_service
    file_list:
      - path: lorawan_beacon_tx_service_example.h
